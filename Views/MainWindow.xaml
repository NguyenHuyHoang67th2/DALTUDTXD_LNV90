<Window x:Class="DALTUDTXD_KIEMTRADAMTHEP_0024167_67TH2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Phần mềm kiểm tra dầm thép chữ I - TCVN 5575:2012"
        Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#F0F2F5">

  <Window.Resources>
    <SolidColorBrush x:Key="PrimaryBlue"  Color="#1A237E"/>
    <SolidColorBrush x:Key="AccentBlue"   Color="#0D47A1"/>
    <SolidColorBrush x:Key="LightPanel"   Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TextDark"     Color="#263238"/>
    <SolidColorBrush x:Key="TextWhite"    Color="#FFFFFF"/>

    <Style x:Key="RoundedButton" TargetType="Button">
      <Setter Property="Background"      Value="{StaticResource PrimaryBlue}"/>
      <Setter Property="Foreground"      Value="{StaticResource TextWhite}"/>
      <Setter Property="FontWeight"      Value="SemiBold"/>
      <Setter Property="FontSize"        Value="13"/>
      <Setter Property="Cursor"          Value="Hand"/>
      <Setter Property="Height"          Value="45"/>
      <Setter Property="Width"           Value="220"/>
      <Setter Property="Margin"          Value="0,0,0,12"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="border"
                    Background="{TemplateBinding Background}"
                    CornerRadius="8" SnapsToDevicePixels="True">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="border" Property="Background" Value="{StaticResource AccentBlue}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Grid>
    <!-- ================= PHÂN VÙNG 1: GIAO DIỆN KHỞI ĐỘNG BAN ĐẦU ================= -->
    <Grid x:Name="StartupGrid" Visibility="Visible">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="300"/>
      </Grid.ColumnDefinitions>
      <Grid.RowDefinitions>
        <RowDefinition Height="100"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="180"/>
      </Grid.RowDefinitions>

      <!-- Panel nền bên phải -->
      <Border Grid.Column="1" Grid.Row="0" Grid.RowSpan="3"
              Background="#E3E8ED" Margin="10" CornerRadius="15">
        <Border.Effect>
          <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1"/>
        </Border.Effect>
      </Border>

      <!-- Tiêu đề -->
      <StackPanel Grid.Column="0" Grid.Row="0"
                  Orientation="Horizontal" Margin="30,0,0,0">
        <Image Source="/Assets/Images/theppp.jpg" Width="60" Height="60" VerticalAlignment="Center" Stretch="UniformToFill">
          <Image.Style>
            <Style TargetType="Image">
              <Style.Triggers>
                <Trigger Property="Source" Value="{x:Null}">
                  <Setter Property="Visibility" Value="Collapsed"/>
                </Trigger>
              </Style.Triggers>
            </Style>
          </Image.Style>
        </Image>
        <StackPanel VerticalAlignment="Center" Margin="20,0,0,0">
          <TextBlock Text="PHẦN MỀM KIỂM TRA DẦM THÉP CHỮ I" FontSize="20" FontWeight="ExtraBold" Foreground="{StaticResource PrimaryBlue}"/>
          <TextBlock Text="Theo TCVN 5575:2012 | Bền uốn, cắt, ổn định tổng thể và cục bộ" FontSize="11" Foreground="#546E7A" Margin="0,4,0,0"/>
        </StackPanel>
      </StackPanel>

      <!-- Nhãn bảng điều khiển -->
      <Border Grid.Column="0" Grid.Row="1" Background="{StaticResource LightPanel}" CornerRadius="10" Height="40" VerticalAlignment="Top" Margin="30,20,30,0">
        <TextBlock Text="BẢNG ĐIỀU KHIỂN CHI TIẾT" Foreground="{StaticResource AccentBlue}" FontWeight="Bold" VerticalAlignment="Center" Margin="15,0,0,0"/>
      </Border>

      <!-- Ảnh nền steel-background -->
      <Border Grid.Column="0" Grid.Row="1" Margin="30,80,30,20" CornerRadius="10" BorderBrush="#D1D9E0" BorderThickness="1" ClipToBounds="True">
        <Border.Background>
          <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#E8EAF6" Offset="0"/>
            <GradientStop Color="#BBDEFB" Offset="1"/>
          </LinearGradientBrush>
        </Border.Background>
        <Grid>
          <Image x:Name="imgNen" Source="/Assets/Images/steel-background.png" Stretch="UniformToFill" ImageFailed="imgNen_ImageFailed"/>
        </Grid>
      </Border>

      <!-- Menu bên phải -->
      <StackPanel Grid.Column="1" Grid.Row="1" Margin="0,50,0,0" VerticalAlignment="Top" HorizontalAlignment="Center">
        <Button Content="🔧  Tính toán dầm" Style="{StaticResource RoundedButton}" Click="btnTaoMoi_Click"/>
        <Button Content="📄  Mở tài liệu kỹ thuật" Style="{StaticResource RoundedButton}"
 Click="btnMoTaiLieu_Click"/>

        <Button Content="📊  Xuất báo cáo kết quả" Style="{StaticResource RoundedButton}"/>
        <Button Content="⚙  Cấu hình hệ thống" Style="{StaticResource RoundedButton}"/>
      </StackPanel>

      <!-- Nhóm nút hỗ trợ phía dưới bên phải -->
      <StackPanel Grid.Column="1" Grid.Row="2" Margin="0,0,0,30" VerticalAlignment="Bottom" HorizontalAlignment="Center">
        <Button Content="📋  Tiêu chuẩn Việt Nam" Style="{StaticResource RoundedButton}" Background="#546E7A"/>
        <Button Content="❓  Trợ giúp &amp; Liên hệ" Style="{StaticResource RoundedButton}" Background="#546E7A"/>
      </StackPanel>
    </Grid>

    <!-- ================= PHÂN VÙNG 2: FRAME CHIẾM TOÀN MÀN HÌNH (Mặc định ẩn) ================= -->
    <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden" Visibility="Collapsed" Background="#F0F2F5"/>
  </Grid>
</Window>