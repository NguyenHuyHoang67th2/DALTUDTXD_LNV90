                                                    <TextBlock Text=" kN" VerticalAlignment="Center" Foreground="#78909C" Margin="3,0,0,0"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,20,5">
                                                    <TextBlock Text="Hệ số ảnh hưởng hình dạng η = " VerticalAlignment="Center" Foreground="#546E7A" FontSize="12"/>
                                                    <TextBox x:Name="txtInput_Eta" Width="60" Height="25" Text="{Binding ShapeFactorEta, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" Padding="5,0"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                                    <TextBlock Text="Hệ số nén lệch tâm φe (Tra bảng D.10) = " VerticalAlignment="Center" Foreground="#D84315" FontWeight="Bold" FontSize="12"/>
