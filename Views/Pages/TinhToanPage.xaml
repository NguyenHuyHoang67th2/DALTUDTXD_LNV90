                                                    <TextBlock Text=" *" VerticalAlignment="Center" Foreground="#D84315" Margin="5,0,0,0" ToolTip="Nhập dạng thập phân, ví dụ: 0.750 (thay vì 750 trong bảng)"/>
                                                </StackPanel>
                                            </WrapPanel>
                                            <TextBlock Text="* Chú thích: Hãy sử dụng 2 giá trị độ mảnh quy ước (λx) và độ lệch tâm tính đổi (me) tính toán bên dưới để tra bảng D.10." FontSize="11" FontStyle="Italic" Foreground="#78909C" Margin="0,5,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <WrapPanel Margin="0,0,0,10">
                                        <TextBlock Style="{StaticResource LabelCheckText}" Margin="0,0,20,5"><Run Text="Độ mảnh thực tế λx = "/> <Run Text="{Binding Results.LambdaX, StringFormat=0.00, Mode=OneWay}" FontWeight="Bold" Foreground="#37474F"/></TextBlock>
                                        <TextBlock Style="{StaticResource LabelCheckText}" Margin="0,0,20,5"><Run Text="Độ mảnh quy ước λx_quyước = "/> <Run Text="{Binding Results.LambdaXQuyUoc, StringFormat=0.00, Mode=OneWay}" FontWeight="Bold" Foreground="#0D47A1"/></TextBlock>
                                        <TextBlock Style="{StaticResource LabelCheckText}" Margin="0,0,20,5"><Run Text="Độ lệch tâm mx = "/> <Run Text="{Binding Results.Mx_Ecc, StringFormat=0.00, Mode=OneWay}" FontWeight="Bold" Foreground="#37474F"/></TextBlock>
                                        <TextBlock Style="{StaticResource LabelCheckText}" Margin="0,0,0,5"><Run Text="Độ lệch tâm tính đổi me = "/> <Run Text="{Binding Results.Me, StringFormat=0.00, Mode=OneWay}" FontWeight="Bold" Foreground="#0D47A1"/></TextBlock>
                                    </WrapPanel>
                                    <TextBlock Style="{StaticResource LabelCheckText}" Margin="0,0,0,5"><Run Text="Công thức kiểm tra ổn định: "/> <Run Text="N / (φe * A) ≤ f * γc" FontWeight="Bold" Foreground="#37474F"/></TextBlock>
                                    <TextBlock Style="{StaticResource LabelCheckText}" Margin="0,0,0,5"><Run Text="Ứng suất ổn định trong mặt phẳng: "/> <Run Text="{Binding Results.SigmaInPlane, StringFormat=0.00, Mode=OneWay}" FontWeight="Bold" Foreground="#0D47A1"/> <Run Text=" MPa"/></TextBlock>
                                    <TextBlock Style="{StaticResource LabelCheckText}"><Run Text="Cường độ chịu nén cho phép: "/> <Run Text="{Binding Results.LimitF, StringFormat=0.00, Mode=OneWay}" FontWeight="Bold" Foreground="#2E7D32"/> <Run Text=" MPa"/></TextBlock>
                                </StackPanel>
                                <Border x:Name="badgeInPlaneCheck" Grid.Column="1" CornerRadius="8" Width="150" Height="40" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <TextBlock x:Name="lblBadgeInPlaneCheck" Text="-" FontWeight="Bold" Foreground="White" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- CARD 2.4: ỔN ĐỊNH CỤC BỘ CÁNH DẦM -->
                        <Border BorderBrush="{StaticResource BorderGray}" BorderThickness="1" CornerRadius="10" Padding="20" Background="White" Margin="0,15,0,15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="180"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="2.4. KIỂM TRA ĐIỀU KIỆN ỔN ĐỊNH CỤC BỘ BẢN CÁNH DẦM" FontWeight="Bold" FontSize="14" Foreground="#1A237E" Margin="0,0,0,10"/>
                                    <TextBlock Style="{StaticResource LabelCheckText}" Margin="0,0,0,5"><Run Text="Công thức kiểm tra: "/> <Run Text="b0 / tf ≤ [b0 / tf] = (0.36 + 0.10 * λ_max) * √(E / f)" FontWeight="Bold" Foreground="#37474F"/></TextBlock>
                                    <TextBlock Style="{StaticResource LabelCheckText}" Margin="0,0,0,5"><Run Text="Phần bản cánh nhô ra b0: "/> <Run Text="{Binding Results.B0, StringFormat=0.000, Mode=OneWay}" FontWeight="Bold" Foreground="#37474F"/> <Run Text=" m  |  (b0 = [bf - tw] / 2)" Foreground="#78909C"/></TextBlock>
                                    <TextBlock Style="{StaticResource LabelCheckText}" Margin="0,0,0,5"><Run Text="Tỉ số độ mảnh bản cánh thực tế (b0 / tf): "/> <Run Text="{Binding Results.RatioB0Tf, StringFormat=0.00, Mode=OneWay}" FontWeight="Bold" Foreground="#0D47A1"/></TextBlock>
                                    <TextBlock Style="{StaticResource LabelCheckText}"><Run Text="Trị số giới hạn cho phép [b0 / tf] (Bảng 34): "/> <Run Text="{Binding Results.LimitB0Tf, StringFormat=0.00, Mode=OneWay}" FontWeight="Bold" Foreground="#2E7D32"/> <Run x:Name="txtValLambdaMaxDetail" Text=" (với λ_max = 2.00)" Foreground="#78909C" FontSize="11"/></TextBlock>
                                </StackPanel>
                                <Border x:Name="badgeFlangeLocalCheck" Grid.Column="1" CornerRadius="8" Width="150" Height="40" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <TextBlock x:Name="lblBadgeFlangeLocalCheck" Text="-" FontWeight="Bold" Foreground="White" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- CARD 2.5: ỔN ĐỊNH CỤC BỘ BẢN BỤNG DẦ -->
                        <Border BorderBrush="{StaticResource BorderGray}" BorderThickness="1" CornerRadius="10" Padding="20" Background="White" Margin="0,0,0,15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="180"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="2.5. KIỂM TRA ĐIỀU KIỆN ỔN ĐỊNH CỤC BỘ BẢN BỤNG DẦM" FontWeight="Bold" FontSize="14" Foreground="#1A237E" Margin="0,0,0,15"/>
                                    <Border Background="#F5F7FA" CornerRadius="6" Padding="15" Margin="0,0,0,15">
                                        <StackPanel>
                                            <TextBlock Text="⚙️ Cấu hình điều kiện tải trọng và loại sườn cấu tạo:" FontWeight="Bold" Foreground="#37474F" FontSize="12" Margin="0,0,0,10"/>
                                            <WrapPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,25,5">
                                                    <TextBlock Text="Loại tải trọng tác dụng: " VerticalAlignment="Center" Foreground="#546E7A" FontSize="12"/>
                                                    <ComboBox x:Name="cboLoadTypeWeb" Width="200" Height="25" SelectedIndex="{Binding LoadTypeWebIndex, Mode=TwoWay}" VerticalContentAlignment="Center" SelectionChanged="cboLoadTypeWeb_SelectionChanged">
                                                        <ComboBoxItem Content="Tải trọng TĨNH (Giới hạn λw_gh = 3.2)"/>
                                                        <ComboBoxItem Content="Tải trọng ĐỘNG (Giới hạn λw_gh = 2.2)"/>
                                                    </ComboBox>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                                    <TextBlock Text="Phương án bố trí sườn ngang: " VerticalAlignment="Center" Foreground="#546E7A" FontSize="12"/>
                                                    <ComboBox x:Name="cboRibLayout" Width="240" Height="25" SelectedIndex="{Binding RibLayoutIndex, Mode=TwoWay}" VerticalContentAlignment="Center" SelectionChanged="cboRibLayout_SelectionChanged">
                                                        <ComboBoxItem Content="Bố trí cặp sườn ngang đối xứng hai bên"/>
                                                        <ComboBoxItem Content="Chỉ bố trí sườn ngang một bên bản bụng"/>
                                                    </ComboBox>
                                                </StackPanel>
                                            </WrapPanel>
                                        </StackPanel>
                                    </Border>
                                    <WrapPanel Margin="0,0,0,10">
                                        <TextBlock Style="{StaticResource LabelCheckText}" Margin="0,0,25,5"><Run Text="Tỷ số độ mảnh bản bụng (hw / tw) = "/> <Run Text="{Binding Results.RatioHwTw, StringFormat=0.00, Mode=OneWay}" FontWeight="Bold" Foreground="#37474F"/></TextBlock>
                                        <TextBlock Style="{StaticResource LabelCheckText}" Margin="0,0,25,5"><Run Text="Độ mảnh quy ước bản bụng λw = "/> <Run Text="{Binding Results.LambdaW, StringFormat=0.00, Mode=OneWay}" FontWeight="Bold" Foreground="#0D47A1"/></TextBlock>
                                        <TextBlock Style="{StaticResource LabelCheckText}" Margin="0,0,0,5"><Run Text="Trị số giới hạn kiểm tra λw_gh = "/> <Run Text="{Binding Results.LimitLambdaW, StringFormat=0.1, Mode=OneWay}" FontWeight="Bold" Foreground="#2E7D32"/></TextBlock>
                                    </WrapPanel>
                                    <Border Background="#ECEFF1" CornerRadius="6" Padding="15,10">
                                        <StackPanel>
                                            <TextBlock Text="📋 KẾT LUẬN VỀ YÊU CẦU CẤU TẠO SƯỜN CỨNG:" FontWeight="Bold" Foreground="#37474F" FontSize="12" Margin="0,0,0,6"/>
                                            <TextBlock x:Name="txtWebStatusText" Text="Bản bụng đủ dày tự bảo đảm ổn định cục bộ. Không cần bố trí sườn cứng dọc nhịp dầm." FontSize="12.5" Foreground="#2E7D32" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                            <TextBlock x:Name="txtWebDetailText" Text="" FontSize="12" Foreground="#37474F" TextWrapping="Wrap" Margin="0,5,0,0" Visibility="Collapsed"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                                <Border x:Name="badgeWebLocalCheck" Grid.Column="1" CornerRadius="8" Width="150" Height="40" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <TextBlock x:Name="lblBadgeWebLocalCheck" Text="-" FontWeight="Bold" Foreground="White" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ================= TAB 4: KIỂM TRA ĐỘ VÕNG ================= -->
            <TabItem Header="4. Kiểm tra độ võng" IsEnabled="False"/>
        </TabControl>
    </Grid>
</Page>