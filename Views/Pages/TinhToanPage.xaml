                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="180"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="2.3. KIỂM TRA ĐIỀU KIỆN ỔN ĐỊNH TRONG MẶT PHẲNG UỐN (NÉN LỆCH TÂM)" FontWeight="Bold" FontSize="14" Foreground="#1A237E" Margin="0,0,0,15"/>
                                    <Border Background="#F5F7FA" CornerRadius="6" Padding="15" Margin="0,0,0,15">
                                        <StackPanel>
                                            <TextBlock Text="⚙️ Thông số tải trọng và hệ số nén lệch tâm:" FontWeight="Bold" Foreground="#37474F" FontSize="12" Margin="0,0,0,10"/>
